[Unit]
Description=Brain Agent API Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/brain-agent
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/opt/brain-agent/.env
ExecStart=/opt/brain-agent/.venv/bin/python -m uvicorn api.server:app --host 0.0.0.0 --port 8080 --workers 1
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
